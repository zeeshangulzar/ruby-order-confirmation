<div class="success-card">
  <div class="check">✓</div>
  <h1>Payment successful</h1>
  <p>Your order confirmation email is on its way. Once Stripe delivers the <code>checkout.session.completed</code> webhook to this app, the email is sent via the Mailtrap Email API.</p>
  <p><%= link_to "Back to store", root_path, class: "back-link" %></p>
</div>

<style>
  body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Arial, sans-serif; background: #f6f6f6; margin: 0; padding: 48px 24px; color: #222; }
  .success-card { max-width: 480px; margin: 0 auto; background: #fff; border-radius: 8px; padding: 40px; text-align: center; box-shadow: 0 2px 8px rgba(0,0,0,.05); }
  .check { font-size: 48px; color: #22c55e; margin-bottom: 8px; }
  .success-card h1 { margin: 0 0 12px 0; }
  .success-card p { color: #555; }
  code { background: #f0f0f0; padding: 2px 6px; border-radius: 4px; font-size: 13px; }
  .back-link { color: #635bff; text-decoration: none; font-weight: 600; }
</style>
